# =============================================================
# Mission Control — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# Never commit .env or .env.local to version control.
# =============================================================

# ---- Authentication ------------------------------------------
AUTH_ENABLED=false                  # Set to 'true' to require login
AUTH_MODE=local                     # 'local' | 'jwt' | 'oauth'
AUTH_SECRET_KEY=                    # Required in production: openssl rand -base64 32
AUTH_SESSION_DURATION=86400         # Seconds (default 24h)
AUTH_ALLOWED_USERS=chief-architect  # Comma-separated usernames
CHIEF_ARCHITECT_PASSWORD=           # Required in production

# ---- Telegram ------------------------------------------------
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_POLLING_MODE=false
TELEGRAM_POLLING_INTERVAL=300

# ---- Discord -------------------------------------------------
ENABLE_DISCORD=false
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=
DISCORD_AVATAR_URL=
DISCORD_STATUS_WEBHOOK=
DISCORD_ALERTS_WEBHOOK=
DISCORD_LOGS_WEBHOOK=

# ---- Supabase ------------------------------------------------
ENABLE_SUPABASE=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Redis / BullMQ -----------------------------------------
ENABLE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- LLM Providers ------------------------------------------
ENABLE_LLM=false
LLM_DEFAULT_PROVIDER=openai         # 'openai' | 'anthropic' | 'kimi'
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_BASE_URL=
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5
KIMI_BASE_URL=

# ---- App Settings -------------------------------------------
APP_NAME=Mission Control
APP_VERSION=0.1.0
NODE_ENV=development
LOG_LEVEL=info
